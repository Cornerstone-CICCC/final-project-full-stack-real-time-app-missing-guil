---
import "../styles/global.css";

interface Props {
  title?: string;
  form?: string;
  container?: string;
}

const { title = "MatchDay", form = "", container = "max-w-sm" } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title></head
  >
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Baskervville:ital,wght@0,400..700;1,400..700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
    rel="stylesheet"
  />
</html>
<body>
  <div
    class="login-bg relative flex min-h-screen items-center justify-center overflow-hidden px-6 py-8 "
  >
    <div class="absolute inset-0"></div>

    <div class={`relative z-10 w-full ${container}`}>
      <div
        class={`rounded-2xl bg-bg/90 p-8 shadow-xl ${form}`}
      >
        <slot />
      </div>
    </div>
  </div>
</body>
