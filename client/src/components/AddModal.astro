---
import Button from "./Button.astro";
import TextField from "./TextField.astro";
---

<!-- Backdrop -->
<div
  id="add-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
  aria-hidden="true"
>
  <div
    id="add-modal-panel"
    class="bg-bg rounded-2xl shadow-2xl p-8 w-full max-w-sm mx-4 flex flex-col gap-5"
  >

    <div class="text-center">
      <h2 class="text-2xl font-bold text-text-black">Add New Contact</h2>
      <p class="mt-1 text-sm text-text-gray">Paste your friend's username below</p>
    </div>

    <form id="add-form" class="space-y-4" action="/chat">
      <TextField name="inviteCode" placeholder="Paste Username*" required />
      <Button type="submit" variant="primary" class="w-full cursor-pointer">Add a new contact</Button>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('add-modal');
  const addForm = document.getElementById('add-form') as HTMLFormElement;

  const open = () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    modal?.setAttribute('aria-hidden', 'false');
  };

  const close = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    modal?.setAttribute('aria-hidden', 'true');
  };

  document.getElementById('close-add-modal')?.addEventListener('click', close);

  // Close when clicking the dark backdrop
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) close();
  });

  // Listen for the open trigger dispatched by the Add Room button
  document.addEventListener('open-add-modal', open);

  
  // == Handle Form Submit & Call createGroupChat API ==
  
  addForm?.addEventListener('submit', async (e) => {
    // Prevent the default browser redirect
    e.preventDefault();

    // Extract the entered username from the TextField
    const formData = new FormData(addForm);
    const inviteCode = formData.get('inviteCode') as string;

    if (!inviteCode) return;

    try {
      // Call the backend REST API to create a new chat room
      // Note: We format the payload to match the createGroupChat controller expectations
      const res = await fetch("http://localhost:3000/api/chats/group", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          name: `Chat with ${inviteCode}`,
          participantIds: [inviteCode]
        }),
      });

      const data = await res.json();

      if (res.ok) {
        console.log("[Frontend] Successfully created new chat:", data);
        addForm.reset();
        close();
        
        // Refresh the page to reload the sidebar with the new chat
        window.location.reload();
      } else {
        alert("Error creating chat: " + data.error);
      }
    } catch (error) {
      console.error("[Frontend Error] Creating chat failed:", error);
      alert("Failed to connect to the server.");
    }
  });
</script>