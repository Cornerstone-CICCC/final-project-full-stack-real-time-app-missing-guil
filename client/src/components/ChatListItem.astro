---
import "../styles/global.css";
import Avatar from "./Avatar.astro";

interface Props {
  avatar: string;
  name: string;
  status: "online" | "offline";
  timestamp?: string;
  unread?: number;
  href?: string;
  active?: boolean;
}

const {
  avatar,
  name,
  status = "offline",
  timestamp,
  unread = 0,
  href = "#",
  active = false
} = Astro.props as Props;
---

<a
  href={href}
  class={`flex items-center gap-4 p-4 rounded-lg cursor-pointer transition-colors hover:bg-primary-10 ${
    active ? "bg-primary-10" : ""
  }`}
>
  <!-- Avatar -->
  <Avatar image={avatar} name={name} />

  <!-- Content -->
  <div class="flex-1">
    
    <!-- Name + timestamp -->
    <div class="flex items-center justify-between">
      <span class="font-medium">{name}</span>

      {timestamp && (
        <span class="text-sm text-text-gray">{timestamp}</span>
      )}
    </div>

    <!-- Status + unread -->
    <div class="flex items-center gap-2 mt-1">

      <!-- STATUS -->
      <div
        class={`flex items-center gap-1 text-sm font-medium ${
          status === "online" ? "text-green" : "text-gray-400"
        }`}
      >
        <span
          class={`h-2 w-2 rounded-full ${
            status === "online" ? "bg-green" : "bg-gray-300"
          }`}
        />
        <span>{status}</span>
      </div>

      <!-- UNREAD -->
      {unread > 0 && (
        <span class="ml-auto inline-flex h-5 w-5 items-center justify-center rounded-full bg-green-500 text-white text-xs font-medium">
          {unread}
        </span>
      )}

    </div>
  </div>
</a>