---
import Button from "./Button.astro";
import TextField from "./TextField.astro";
---

<div
  id="invite-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
  aria-hidden="true"
>
  <div
    id="invite-modal-panel"
    class="bg-bg rounded-2xl shadow-2xl p-8 w-full max-w-sm mx-4 flex flex-col gap-5"
  >
    <div class="text-center">
      <h2 class="text-2xl font-bold text-text-black">Have an invite link already?</h2>
      <p class="mt-1 text-sm text-text-gray">Paste it below to join a room</p>
    </div>

    <form id="invite-form" class="space-y-4">
      <TextField name="inviteCode" placeholder="Paste invite link or code" required />
      <Button type="submit" variant="primary" class="w-full cursor-pointer">Join Room</Button>
    </form>

    <div class="flex items-center gap-3">
      <hr class="flex-1 border-text-gray-50" />
      <span class="text-xs text-text-gray">or</span>
      <hr class="flex-1 border-text-gray-50" />
    </div>

    <Button variant="neutral" class="w-full cursor-pointer" href="/rooms/room-settings">Create a Room</Button>

  </div>
</div>

<script>
  const modal = document.getElementById('invite-modal');
  const inviteForm = document.getElementById('invite-form') as HTMLFormElement;

  const open = () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    modal?.setAttribute('aria-hidden', 'false');
  };

  const close = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    modal?.setAttribute('aria-hidden', 'true');
    if (inviteForm) inviteForm.reset(); 
  };

  document.getElementById('close-invite-modal')?.addEventListener('click', close);

  // Close when clicking the dark backdrop
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) close();
  });

  // Listen for the open trigger dispatched by the Add Room button
  document.addEventListener('open-invite-modal', open);

  // =========================================================================
  // API INTEGRATION: JOIN GROUP CHAT
  // =========================================================================
  inviteForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(inviteForm);
    const inviteCode = formData.get('inviteCode') as string;

    if (!inviteCode) return;

    try {
      // 1. Send the Room ID (inviteCode) to the backend Join endpoint
      const res = await fetch("http://localhost:3000/api/chats/join", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ chatId: inviteCode.trim() }),
      });

      const data = await res.json();

      if (res.ok) {
        // 2. Success! Close the modal
        close();
        
        // 3. Reload the page so the newly joined room appears in the sidebar
        window.location.reload();
      } else {
        // Handle explicit errors from backend (e.g., "Room not found", "Already joined")
        alert("Failed to join room: " + (data.error || "Invalid Room ID"));
      }
    } catch (error) {
      console.error("Join Room Error:", error);
      alert("Server connection failed. Please try again.");
    }
  });
</script>