---
interface Props {
  id?: string;
  message?: string;
  class?: string;
}

const {
  id = "typing-indicator",
  message = "",
  class: className = "",
} = Astro.props as Props;
---

<div id={id} class={`rounded-full relative px-6 py-1 text-sm font-medium bg-primary-10 text-primary w-fit ${className}`}>
  {message}
</div>
