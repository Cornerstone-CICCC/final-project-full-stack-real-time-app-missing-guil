---
import Button from "./Button.astro";

interface Props {
  teamA: string;
  teamB: string;
  score?: string;
  memberCount?: number;
  teamAFlag: string;
  teamBFlag: string;
  matchTime: string;
  group?: string;
  href?: string;
  stage: string;
  status?: "live" | "upcoming";
}

const {
  teamA,
  teamB,
  score,
  memberCount = 0,
  teamAFlag,
  teamBFlag,
  matchTime,
  group,
  href = "/rooms/:id",
  stage,
  status = "upcoming",
} = Astro.props as Props;
---

<div
  class="shadow-md px-4 py-6 sm:px-6 md:px-8 rounded-2xl bg-bg/90 w-full max-w-3xl flex flex-col"
>
  <!-- Match Meta -->
  <div class="flex justify-center mb-4">
    <span
      class="rounded-full bg-primary/10 px-4 py-1 text-xs sm:text-sm font-medium text-primary-60"
    >
      {stage} • Group {group}
    </span>
  </div>

  <!-- Teams -->
  <div class="flex items-center justify-between gap-2">
    <!-- Team A -->
    <div class="flex flex-col items-center gap-2 flex-1">
      <img
        src={teamAFlag}
        alt={`${teamA} flag`}
        class="w-12 sm:w-16 md:w-24 h-auto rounded-lg shadow-md"
      />

      <span
        class="text-sm sm:text-lg md:text-2xl font-semibold text-center"
      >
        {teamA}
      </span>
    </div>

    <!-- Center -->
    <div class="flex flex-col items-center gap-3 shrink-0">
      <span
        class="text-3xl sm:text-4xl md:text-6xl font-bold text-primary-60"
      >
        {score || "VS"}
      </span>

      {
        status === "live" ? (
          <span
            class="rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-600"
          >
            🔴 {matchTime}
          </span>
        ) : (
          <span
            class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600"
          >
            {matchTime}
          </span>
        )
      }
    </div>

    <!-- Team B -->
    <div class="flex flex-col items-center gap-2 flex-1">
      <img
        src={teamBFlag}
        alt={`${teamB} flag`}
        class="w-12 sm:w-16 md:w-24 h-auto rounded-lg shadow-md"
      />

      <span
        class="text-sm sm:text-lg md:text-2xl font-semibold text-center"
      >
        {teamB}
      </span>
    </div>
  </div>

  <!-- CTA -->
  <div class="mt-6 flex justify-center">
    {
      {
        live: (
          <Button variant="primary" href={href}>
            Join Room
          </Button>
        ),
        upcoming: (
          <Button variant="primary" disabled>
            Available Soon
          </Button>
        ),
      }[status]
    }
  </div>
</div>
