---
import Button from "./Button.astro";

interface Props {
  teamA: string;
  teamB: string;
  score?: string;
  memberCount?: number;
  teamAFlag: string;
  teamBFlag: string;
  matchTime: string;
  href?: string;
  status?: "live" | "upcoming";
}

const {
  teamA,
  teamB,
  score,
  memberCount = 0,
  teamAFlag,
  teamBFlag,
  matchTime,
  href = "/rooms/:id",
  status = "upcoming",
} = Astro.props as Props;
---

<div class=" border-b-1 border-primary pb-8 pt-6 px-8">
  <div class="flex items-center justify-between ">
    <div class="flex flex-col items-center gap-2">
      <img
        src={teamAFlag}
        alt={`${teamA} flag`}

        />
      <span class="text-2xl font-medium">{teamA}</span>
    </div>
    <div class="flex flex-col items-center gap-2">
      <span class="text-6xl font-bold text-primary-60 px-4 py-2"
        >{score || "VS"}</span
      >
      <span class="text-sm font-medium rounded-4xl bg-red-300/60 px-4 py-2 text-red-600">{matchTime}</span>
    </div>
    <div class="flex flex-col items-center gap-2">
      <img
        src={teamBFlag}
        alt={`${teamB} flag`}
  />
      <span class="text-2xl font-medium">{teamB}</span>
    </div>
  </div>
  <div class="mt-4 flex flex-col items-center justify-between gap-4 max-w-sm mx-auto">


    {
      {
        live: (
          <Button variant="primary" href={href}>
            Join Room
          </Button>
        ),
        upcoming: (
          <Button variant="primary" disabled>
            Available Soon
          </Button>
        ),
      }[status]
    }
  </div>
</div>
