---
import "../styles/global.css";

import emojiIcon from "../assets/icon/green/emoji.svg?url";
import sendIcon from "../assets/icon/green/send.svg?url";


---

<form id="chat-form" class="relative flex items-center gap-3 px-12 pt-4 pb-10 bg-transparent">


  <div class="flex flex-row flex-1  rounded-xl border-text-gray-50 gap-7 bg-bg/90 px-5 py-2.5 text-sm text-text-black placeholder:text-text-gray focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
    <button
    type="button"
    class="shrink-0 text-text-gray hover:text-primary transition-colors"
    aria-label="Emoji"
  >
    <img src={emojiIcon} alt="Emoji" class="h-5 w-5" />

  </button>

  <input
    type="text"
    id="message-input"
    placeholder="Message"
    autocomplete="off"
    class="text-sm text-text-black placeholder:text-text-gray  focus:outline-none w-full"
  />

  <button
    type="submit"
    class="shrink-0 h-10 w-10 rounded-full bg-transparent flex items-center justify-center hover:bg-primary-10 transition-colors cursor-pointer"
    aria-label="Send"
  >
    <img src={sendIcon} alt="Send" class="h-7 w-7 opacity-60 hover:opacity-100 transition-opacity" />
  </button>
  </div>
</form>
