---
import "../styles/global.css";

interface Props {
  variant?: "primary" | "neutral" | "subtle";
  type?: "button" | "submit" | "reset";
  href?: string;
  id?: string;
  class?: string;
  disabled?: boolean;
}

const {
  variant = "primary",
  type = "button",
  href,
  id,
  class: className = "",
  disabled = false,
} = Astro.props as Props;

const base =
  "inline-flex items-center justify-center gap-2 p-3 rounded-lg font-medium transition-colors";

const variants: Record<string, string> = {
  primary: "bg-primary text-bg hover:bg-black",
  neutral:
    "bg-primary-10 text-primary border border-primary-20 hover:bg-primary-20",
  subtle: "bg-transparent text-primary hover:bg-primary-10",
};

const disabledStyle =
  "bg-text-gray border border-gray-300 pointer-events-none opacity-60";
const classes = `
  ${base}
  ${variants[variant]}
  ${disabled ? disabledStyle : ""}
  ${className}
`;
---

{
  href ? (
    <a id={id} href={disabled ? undefined : href} class={classes}>
      <slot />
    </a>
  ) : (
    <button id={id} type={type} class={classes} disabled={disabled}>
      <slot />
    </button>
  )
}
