---
export const prerender = false;

import MainLayout from "../../layouts/MainLayout.astro";
import SearchField from "../../components/SearchField.astro";
import ChatListItem from "../../components/ChatListItem.astro";
import RoomIcon from "../../assets/icon/green/rooms.svg?url";

import RoomHeader from "../../components/RoomHeader.astro";
import ChatBubble from "../../components/ChatBubble.astro";
import TypeBox from "../../components/TypeBox.astro";
import TypingIndicator from "../../components/TypingIndicator.astro";

import Button from "../../components/Button.astro";
import PlusIcon from "../../assets/icon/outlined/plus.svg?url";

import InviteModal from "../../components/InviteModal.astro";

// fake data (replace with DB later)
type Message = {
  text: string;
  timestamp: string;
  isOwn: boolean;
  read?: boolean;
  reaction?: string;
};

type Member = {
  name: string;
  avatar: string;
  status: "online" | "offline";
};

type Room = {
  id: string;
  name: string;
  status: "online" | "offline";
  avatar: string;
  timestamp: string;
  unread?: number;
  memberCount: number;
  onlineCount: number;
  members: Member[];
  messages: Message[];
};

const rooms: Room[] = [
  {
    id: "1",
    name: "Australia VS Turkey",
    status: "online",
    avatar: "/assets/images/user1.jpg",
    timestamp: "2:30 PM",
    unread: 3,
    memberCount: 123,
    onlineCount: 12,
    members: [
      { name: "John Doe",   avatar: "", status: "online"  },
      { name: "Jane Smith", avatar: "", status: "online"  },
      { name: "Bob K.",     avatar: "", status: "offline" },
    ],
    messages: [
      { text: "OMG 🤫 do you remember what you did last night at the work night out?", timestamp: "18:12", isOwn: false, reaction: "❤️" },
      { text: "no haha",                    timestamp: "18:16", isOwn: true, read: true },
      { text: "i don't remember anything 😅", timestamp: "18:16", isOwn: true, read: true },
    ],
  },
  {
    id: "2",
    name: "Brazil Fans",
    status: "offline",
    avatar: "/assets/images/user2.jpg",
    timestamp: "1:45 PM",
    memberCount: 54,
    onlineCount: 3,
    members: [
      { name: "Maria G.",  avatar: "", status: "online"  },
      { name: "Carlos R.", avatar: "", status: "offline" },
    ],
    messages: [
      { text: "Vamos Brasil! 🇧🇷", timestamp: "13:00", isOwn: false },
      { text: "Let's go!",          timestamp: "13:01", isOwn: true, read: true },
    ],
  },
  {
    id: "3",
    name: "Germany is the best",
    status: "online",
    avatar: "/assets/images/user3.jpg",
    timestamp: "12:00 PM",
    memberCount: 88,
    onlineCount: 7,
    members: [
      { name: "Leo M.",  avatar: "", status: "online"  },
      { name: "Anna K.", avatar: "", status: "online"  },
      { name: "Hans B.", avatar: "", status: "offline" },
    ],
    messages: [
      { text: "Germany scored! ⚽", timestamp: "11:55", isOwn: false },
      { text: "Amazing goal 🔥",    timestamp: "11:56", isOwn: true, read: true },
    ],
  },
];

const { id } = Astro.params;
const activeRoom = rooms.find((r) => r.id === id);
---

<MainLayout title="Rooms" active="Rooms" container="w-full">
  <div class="flex h-screen">

    <!-- LEFT: Room list -->
    <aside class="w-100 p-4 flex flex-col shadow-lg">

      <div class="flex flex-row justify-between items-center">

      <h1 class="text-3xl font-bold mb-4 flex items-center gap-2 text-primary-60">
        <img src={RoomIcon} alt="Rooms" class="h-8 w-8" />
        Rooms
      </h1>

      <Button id="open-invite-modal" variant="primary" class="text-sm mb-4 cursor-pointer">
        <img src={PlusIcon} alt="Add Room" class="h-5 w-5" />
        Add Room
      </Button>
      </div>

      <SearchField placeholder="Search..." />

      <div class="mt-4 space-y-2 overflow-y-auto flex-1">
        {rooms.map((room) => (
          <div class="room-trigger" data-room-id={room.id}>
            <ChatListItem
              avatar={room.avatar}
              name={room.name}
              status={room.status}
              timestamp={room.timestamp}
              href={`#`}
              active={room.id === id}
              unread={room.unread}
            />
          </div>
        ))}
      </div>
    </aside>

    <!-- RIGHT: Chat window -->
    <div class="flex-1 relative flex flex-col overflow-hidden bg-bg">

      {activeRoom ? (
        <>
          <div id={`room-panel-${activeRoom.id}`} class="room-panel hidden flex-1 flex-col h-full overflow-hidden">
            <RoomHeader
              name={activeRoom.name}
              avatar={activeRoom.avatar}
              memberCount={activeRoom.memberCount}
              onlineCount={activeRoom.onlineCount}
              members={activeRoom.members}
            />

            <div class="home-bg absolute inset-0 opacity-40 pointer-events-none" />

            <div id={`messages-list-${activeRoom.id}`} class="relative flex-1 overflow-y-auto px-6 py-4 flex flex-col gap-1">
              <!-- Date separator -->
              <div class="flex items-center gap-3 my-3">
                <hr class="flex-1 border-gray-300/60" />
                <span class="text-xs font-medium text-gray-500 bg-white/70 px-3 py-0.5 rounded-full backdrop-blur-sm">
                  Today
                </span>
                <hr class="flex-1 border-gray-300/60" />
              </div>

              {activeRoom.messages.map((msg: Message) => (
                <ChatBubble
                  message={msg.text}
                  timestamp={msg.timestamp}
                  isOwn={msg.isOwn}
                  reaction={msg.reaction}
                  read={msg.read}
                />
              ))}
            </div>

            <TypingIndicator id={`typing-${activeRoom.id}`} />
            <TypeBox />
          </div>
        </>
      ) : (
        <>
          <div class="home-bg absolute inset-0 opacity-30" />
          <p class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-gray-500 text-lg text-center z-10">
            Select a room to start messaging
          </p>
        </>
      )}
    </div>

  </div>
  <InviteModal />
</MainLayout>

<script>
  // ── Room switching ──────────────────────────────────────────────────────
  const emptyState = document.getElementById('empty-state');
  let activeId: string | null = null;

  function openRoom(id: string) {
    // Hide previous panel
    if (activeId) {
      const prev = document.getElementById(`room-panel-${activeId}`);
      prev?.classList.replace('flex', 'hidden');
    }

    // Hide empty state
    emptyState?.classList.add('hidden');

    // Show new panel
    const panel = document.getElementById(`room-panel-${id}`);
    if (panel) {
      panel.classList.remove('hidden');
      panel.classList.add('flex');
      // Scroll to bottom
      const list = document.getElementById(`messages-list-${id}`);
      if (list) list.scrollTop = list.scrollHeight;
    }

    activeId = id;

    // Highlight active list item
    document.querySelectorAll<HTMLElement>('.room-trigger').forEach((el) => {
      const isActive = el.dataset.roomId === id;
      el.querySelector('a')?.classList.toggle('bg-primary-10', isActive);
    });
  }

  // Attach click listeners to each list item wrapper
  document.querySelectorAll<HTMLElement>('.room-trigger').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const id = el.dataset.roomId;
      if (id) openRoom(id);
    });
  });

  // ── Invite modal ────────────────────────────────────────────────────────
  document.getElementById('open-invite-modal')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-invite-modal'));
  });
</script>


