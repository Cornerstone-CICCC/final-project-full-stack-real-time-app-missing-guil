<html>
<body>
  <div class="card">
    <h1>Log In</h1>
    <p>Please enter your account info</p>
    
    <input type="text" name="username" placeholder="Username" />
    <p id="username-error" class="error-msg"></p>

    <input type="password" name="password" placeholder="Password" />
    <p id="password-error" class="error-msg"></p>

    <button id="loginBtn">Log In</button>
    <p class="footer-text">Don't have an account? <a href="/register">Register</a></p>
  </div>

  <script>
    const btn = document.getElementById('loginBtn');
    
    btn?.addEventListener('click', async () => {
      document.querySelectorAll('.error-msg').forEach(el => (el as HTMLElement).textContent = '');
      document.querySelectorAll('input').forEach(el => (el as HTMLElement).style.borderColor = '#ccc');

      const username = (document.querySelector('input[name="username"]') as HTMLInputElement).value;
      const password = (document.querySelector('input[name="password"]') as HTMLInputElement).value;

      let hasError = false;
      if (!username) { document.getElementById('username-error')!.textContent = "Username is required"; hasError = true; }
      if (!password) { document.getElementById('password-error')!.textContent = "Password is required"; hasError = true; }
      if (hasError) return;

      try {
        const res = await fetch('http://localhost:3000/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password })
        });
        
        const data = await res.json();
        if (!res.ok) {
          const inputEl = document.querySelector(`input[name="${data.field}"]`) as HTMLElement;
          const errorEl = document.getElementById(`${data.field}-error`);
          if (inputEl) inputEl.style.borderColor = 'red';
          if (errorEl) errorEl.textContent = data.error;
        } else {
          window.location.href = '/chat';
        }
      } catch (err) { alert('Server connection failed.'); }
    });
  </script>

  <style>
    body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f4f4f9; font-family: sans-serif; }
    .card { width: 400px; padding: 2.5rem; background: white; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    input { width: 100%; padding: 12px; margin-top: 10px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }
    .error-msg { color: red; font-size: 0.75rem; height: 12px; margin: 5px 0; }
    button { width: 100%; padding: 14px; margin-top: 15px; background: #1a3c17; color: white; border: none; border-radius: 6px; cursor: pointer; }
    .footer-text { color: #888; font-size: 0.8rem; margin-top: 15px; text-align: center; }
    .footer-text a { color: #1a3c17; text-decoration: none; font-weight: bold; }
  </style>
</body>
</html>