---
import AuthLayout from "../../layouts/AuthLayout.astro";
import Button from "../../components/Button.astro";
import TextField from "../../components/TextField.astro";
import CheckBox from "../../components/CheckBox.astro";
---

<AuthLayout title="Register" container="max-w-md">
  <h1 class="font-display text-5xl font-bold text-text-black">Register</h1>
  <p class="mt-1 mb-6 text-sm text-text-gray">
    Please enter your account details
  </p>

  <form id="registerForm" class="space-y-4" method="post">
    <div class="space-y-1">
      <TextField
        name="username"
        placeholder="Username"
        maxlength="15"
        required
      />
      <p
        id="username-error"
        class="error-msg text-red-500 text-xs empty:hidden"
      >
      </p>
    </div>

    <div class="space-y-1">
      <TextField
        name="email"
        type="email"
        placeholder="you@example.com"
        required
      />
      <p id="email-error" class="error-msg text-red-500 text-xs empty:hidden">
      </p>
    </div>

    <div class="space-y-1">
      <div class="relative flex items-center">
        <TextField
          name="password"
          type="password"
          placeholder="Password"
          required
          class="w-full"
        />
        <span
          id="togglePassword"
          class="absolute right-3 cursor-pointer text-xs text-gray-500 select-none"
          >Show</span
        >
      </div>
      <p class="text-gray-400 text-[10px] mt-1">
        At least 5 chars, 1 uppercase, 1 number, 1 special char
      </p>
      <p
        id="password-error"
        class="error-msg text-red-500 text-xs empty:hidden"
      >
      </p>
    </div>

    <div class="space-y-1">
      <div class="relative flex items-center">
        <TextField
          name="confirmPassword"
          type="password"
          placeholder="Confirm Password"
          required
          class="w-full"
        />
        <span
          id="toggleConfirmPassword"
          class="absolute right-3 cursor-pointer text-xs text-gray-500 select-none"
          >Show</span
        >
      </div>
      <p
        id="confirmPassword-error"
        class="error-msg text-red-500 text-xs empty:hidden"
      >
      </p>
    </div>

    <div class="space-y-1">
      <CheckBox
        name="terms"
        class="text-sm text-text-gray w-full whitespace-nowrap"
      >
        I agree with the <a
          href="/"
          class="font-medium text-primary hover:underline"
          >terms of service and privacy policy*</a
        >
      </CheckBox>
      <p id="terms-error" class="error-msg text-red-500 text-xs empty:hidden">
      </p>
    </div>

    <Button type="submit" variant="primary" class="w-full" href='/profile'>Register</Button>
  </form>

  <p class="mt-5 text-center text-sm text-text-gray">
    Already have an account?
    <a href="/" class="font-medium text-primary hover:underline">Log in</a>
  </p>
</AuthLayout>

<script>
  const btn = document.getElementById("registerBtn");
  const togglePass = document.getElementById("togglePassword");
  const toggleConfirm = document.getElementById("toggleConfirmPassword");

  const passInput = document.querySelector(
    'input[name="password"]',
  ) as HTMLInputElement;
  const confirmInput = document.querySelector(
    'input[name="confirmPassword"]',
  ) as HTMLInputElement;
  const termsCheckbox = document.querySelector(
    'input[name="terms"]',
  ) as HTMLInputElement;

  document.querySelectorAll('input:not([name="terms"])').forEach((input) => {
    input.addEventListener("input", () => {
      (input as HTMLElement).style.borderColor = "";
      const errorEl = document.getElementById(
        `${input.getAttribute("name")}-error`,
      );
      if (errorEl) errorEl.textContent = "";
    });
  });

  termsCheckbox?.addEventListener("change", () => {
    if (termsCheckbox.checked) {
      const termsError = document.getElementById("terms-error");
      if (termsError) termsError.textContent = "";
    }
  });

  togglePass?.addEventListener("click", () => {
    const isPassword = passInput.type === "password";
    passInput.type = isPassword ? "text" : "password";
    togglePass.textContent = isPassword ? "Hide" : "Show";
  });

  toggleConfirm?.addEventListener("click", () => {
    const isPassword = confirmInput.type === "password";
    confirmInput.type = isPassword ? "text" : "password";
    toggleConfirm.textContent = isPassword ? "Hide" : "Show";
  });

  btn?.addEventListener("click", async () => {
    document
      .querySelectorAll(".error-msg")
      .forEach((el) => ((el as HTMLElement).textContent = ""));
    document
      .querySelectorAll("input")
      .forEach((el) => ((el as HTMLElement).style.borderColor = ""));

    const username = (
      document.querySelector('input[name="username"]') as HTMLInputElement
    ).value;
    const email = (
      document.querySelector('input[name="email"]') as HTMLInputElement
    ).value;
    const password = passInput.value;
    const confirmPassword = confirmInput.value;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const passRegex = /^(?=.*[A-Z])(?=.*[0-9])(?=.*[!@#$%^&*])(?=.{5,})/;

    let hasError = false;

    if (!username) {
      document.getElementById("username-error")!.textContent =
        "Username is required";
      hasError = true;
    } else if (username.length > 15) {
      document.getElementById("username-error")!.textContent =
        "Username must be 15 characters or less";
      (
        document.querySelector('input[name="username"]') as HTMLElement
      ).style.borderColor = "red";
      hasError = true;
    }

    if (!email) {
      document.getElementById("email-error")!.textContent = "Email is required";
      hasError = true;
    } else if (!emailRegex.test(email)) {
      document.getElementById("email-error")!.textContent =
        "Invalid email format";
      hasError = true;
    }

    if (!password) {
      document.getElementById("password-error")!.textContent =
        "Password is required";
      hasError = true;
    } else if (!passRegex.test(password)) {
      document.getElementById("password-error")!.textContent =
        "Invalid password format";
      hasError = true;
    }

    if (!confirmPassword) {
      document.getElementById("confirmPassword-error")!.textContent =
        "Confirm Password is required";
      hasError = true;
    } else if (password !== confirmPassword) {
      document.getElementById("confirmPassword-error")!.textContent =
        "Passwords do not match";
      hasError = true;
    }

    if (!termsCheckbox.checked) {
      document.getElementById("terms-error")!.textContent =
        "You must agree to the terms";
      hasError = true;
    }

    if (hasError) return;

    const res = await fetch("http://localhost:3000/api/auth/register", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ username, email, password }),
    });

    const data = await res.json();
    if (!res.ok) {
      const errorEl = document.getElementById(`${data.field}-error`);
      if (errorEl) {
        errorEl.textContent = data.error;
        const inputEl = document.querySelector(
          `input[name="${data.field}"]`,
        ) as HTMLElement;
        if (inputEl) inputEl.style.borderColor = "red";
      }
    } else {
      window.location.href = "/";
    }
  });
</script>
