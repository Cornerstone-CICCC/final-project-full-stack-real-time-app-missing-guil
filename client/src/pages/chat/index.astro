---
export const prerender = false;

import MainLayout from "../../layouts/MainLayout.astro";
import SearchField from "../../components/SearchField.astro";
import chatIcon from "../../assets/icon/green/chat.svg?url";

import ChatHeader from "../../components/ChatHeader.astro";
import TypeBox from "../../components/TypeBox.astro";
import TypingIndicator from "../../components/TypingIndicator.astro";

import Button from "../../components/Button.astro";
import PlusIcon from "../../assets/icon/outlined/plus.svg?url";
import AddModal from "../../components/AddModal.astro";

// 1. FETCH AUTHENTICATED USER SESSION

const cookie = Astro.request.headers.get("cookie") || "";
let currentUserId = "78eb3e18-a534-460f-ad45-97a86c121e3c"; // Fallback

try {
  const authRes = await fetch("http://localhost:3000/api/auth/me", {
    headers: { Cookie: cookie }
  });
  if (authRes.ok) {
    const authData = await authRes.json();
    currentUserId = authData.id || authData._id || authData.user?.id || currentUserId;
  }
} catch (error) {
  console.error("Auth fetch failed");
}
---

<MainLayout title="Chat" active="Chat" container="w-full">
	<div
		class="flex h-screen"
		data-my-user-id={currentUserId}
		id="chat-container"
	>
		<div class="w-100 p-4 flex flex-col shadow-lg border-r border-gray-200">
			<div class="flex flex-row justify-between items-center">
				<h1
					class="text-3xl font-bold mb-4 flex items-center gap-2 text-primary-60"
				>
					<img src={chatIcon} alt="Chat Icon" class="h-8 w-8" />
					Chat
				</h1>
				<Button
					id="open-add-modal"
					variant="primary"
					class="text-sm mb-4 cursor-pointer"
				>
					<img src={PlusIcon} alt="Add contact" class="h-5 w-5" />
					Add Contact
				</Button>
			</div>

			<SearchField placeholder="Search..." />

			<div id="chat-sidebar-list" class="mt-4 space-y-2 overflow-y-auto flex-1">
				<p id="chat-list-status" class="text-xs text-gray-400 text-center py-4">
					Loading active chats...
				</p>
			</div>
		</div>

		<div class="flex-1 relative flex flex-col bg-slate-50">
			<div
				id="empty-chat-state"
				class="absolute inset-0 flex items-center justify-center z-10 bg-slate-50"
			>
				<div class="home-bg absolute inset-0 opacity-30 pointer-events-none">
				</div>
				<p class="text-gray-500 text-lg text-center z-10">
					Select a chat to start messaging
				</p>
			</div>

			<div id="active-chat-state" class="hidden flex-col h-full z-20">
				<div id="chat-header-wrapper">
					<ChatHeader
						name="Chat Room"
						status="online"
						avatar=""
						lastTimestamp="Now"
					/>
				</div>

				<div class="home-bg absolute inset-0 opacity-20 pointer-events-none">
				</div>

				<div
					id="messages-list"
					class="relative flex-1 overflow-y-auto px-6 pt-4 pb-4 flex flex-col gap-3"
				>
				</div>

				<div id="typing-indicator-wrapper" class="hidden px-6">
					<TypingIndicator message="Someone is typing ..." />
				</div>

				<div
					id="typebox-container"
					class="bg-white border-t border-gray-200 p-4"
				>
					<TypeBox />
				</div>
			</div>
		</div>
	</div>
</MainLayout>

<AddModal />

<script>
	import { initializeSocket, SOCKET_EVENTS } from "../../lib/socket";

	// 1. DOM Elements
	const sidebarList = document.getElementById("chat-sidebar-list");
	const chatListStatus = document.getElementById("chat-list-status");
	const emptyState = document.getElementById("empty-chat-state");
	const activeState = document.getElementById("active-chat-state");
	const messagesList = document.getElementById("messages-list");
	const chatContainer = document.getElementById("chat-container");
	const chatHeaderWrapper = document.getElementById("chat-header-wrapper");

	const typingIndicatorWrapper = document.getElementById(
		"typing-indicator-wrapper",
	);
	const chatForm = document.getElementById("chat-form") as HTMLFormElement;
	const messageInput = document.getElementById(
		"message-input",
	) as HTMLInputElement;

	let activeChatId: string | null = null;
	const myUserId =
		chatContainer?.getAttribute("data-my-user-id") || "test-user-001";

	// 2. Initialize Socket Connection
	const socket = initializeSocket("http://localhost:3000");

	// Helper Function: Render a single message bubble
	function renderMessage(message: any) {
		if (!messagesList) return;

		const isOwn =
			message.senderId === myUserId ||
			message.sender?._id === myUserId ||
			message.sender === myUserId;

		const wrapperDiv = document.createElement("div");
		wrapperDiv.className = `flex w-full ${isOwn ? "justify-end" : "justify-start"}`;

		const bubbleDiv = document.createElement("div");
		if (isOwn) {
			bubbleDiv.className =
				"max-w-[70%] px-4 py-2.5 rounded-2xl text-sm shadow-sm bg-primary text-white rounded-br-sm";
		} else {
			bubbleDiv.className =
				"max-w-[70%] px-4 py-2.5 rounded-2xl text-sm shadow-sm bg-white text-slate-800 rounded-bl-sm border border-gray-100";
		}

		const textElement = document.createElement("p");
		textElement.className = "leading-relaxed break-words";
		textElement.textContent = message.text || message.content || "";

		bubbleDiv.appendChild(textElement);
		wrapperDiv.appendChild(bubbleDiv);
		messagesList.appendChild(wrapperDiv);

		// Scroll to bottom
		setTimeout(() => {
			messagesList.scrollTop = messagesList.scrollHeight;
		}, 10);
	}

	// =========================================================================
	// API: FETCH CHATS & RENDER SIDEBAR
	// =========================================================================
	async function fetchUserChats() {
		try {
			const res = await fetch("http://localhost:3000/api/chats", {
				method: "GET",
				headers: { "Content-Type": "application/json" },
				credentials: "include",
			});

			const chats = await res.json();

			if (!res.ok) throw new Error(chats.error || "Failed to fetch chats");

			if (sidebarList) {
				if (chatListStatus) chatListStatus.remove();

				if (chats.length === 0) {
					sidebarList.innerHTML = `<p class="text-xs text-gray-400 text-center py-4">No active conversations found.</p>`;
					return;
				}

				chats.forEach((chat: any) => {
					let chatName = chat.name;
					if (
						!chatName ||
						chatName === "null" ||
						chatName.includes("Chat con")
					) {
						const otherUser = chat.participants?.find(
							(p: any) => p._id !== myUserId && p.id !== myUserId,
						);
						chatName =
							otherUser?.username || otherUser?.name || "Direct Message";
					}

					const chatItemLink = document.createElement("a");
					chatItemLink.setAttribute("href", `/chat/${chat._id || chat.id}`);
					chatItemLink.className =
						"chat-trigger block p-3 rounded-xl transition-all hover:bg-slate-100 bg-white shadow-sm border border-gray-100 flex flex-row items-center gap-3 cursor-pointer mb-2";

					chatItemLink.innerHTML = `
            <div class="relative w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold">
              ${chatName.charAt(0).toUpperCase()}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-row justify-between items-baseline">
                <h3 class="text-sm font-semibold text-slate-800 truncate">${chatName}</h3>
                <span class="text-[10px] text-slate-400">Recent</span>
              </div>
            </div>
          `;

					sidebarList.appendChild(chatItemLink);
				});
			}
		} catch (error) {
			console.error("[Frontend Error] Error loading sidebar chats:", error);
		}
	}

	fetchUserChats();

	// =========================================================================
	// SOCKETS: HISTORY & NEW MESSAGES
	// =========================================================================
	if (socket) {
		socket.on(SOCKET_EVENTS.MESSAGE_HISTORY, (messages: any[]) => {
			if (messagesList) {
				messagesList.innerHTML = "";
				messages.forEach(renderMessage);
				setTimeout(() => {
					messagesList.scrollTop = messagesList.scrollHeight;
				}, 50);
			}
		});

		socket.on(SOCKET_EVENTS.NEW_MESSAGE, (message: any) => {
			renderMessage(message);
		});

		let typingTimeout: any;
		socket.on("user_typing", () => {
			if (typingIndicatorWrapper) {
				typingIndicatorWrapper.classList.remove("hidden");
				clearTimeout(typingTimeout);
				typingTimeout = setTimeout(() => {
					typingIndicatorWrapper.classList.add("hidden");
				}, 3000);
			}
		});
	}

	// =========================================================================
	// NAVIGATION INTERCEPTION (SPA ROUTING) & ROOM LEAVING
	// =========================================================================
	sidebarList?.addEventListener("click", (e) => {
		const link = (e.target as HTMLElement).closest("a.chat-trigger");
		if (!link) return;
		e.preventDefault();

		const href = link.getAttribute("href");
		const newChatId = href?.split("/").pop();

		if (newChatId && newChatId !== activeChatId) {
			if (activeChatId && socket)
				socket.emit(SOCKET_EVENTS.LEAVE_CHAT, { chatId: activeChatId });

			activeChatId = newChatId;

			const chatTitleEl = link.querySelector("h3");
			const currentChatName = chatTitleEl
				? chatTitleEl.textContent
				: "Direct Message";

			if (chatHeaderWrapper) {
				chatHeaderWrapper.innerHTML = `
          <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between shadow-sm z-30 relative">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold">${currentChatName?.charAt(0).toUpperCase()}</div>
              <div>
                <h2 class="text-sm font-semibold text-slate-800">${currentChatName}</h2>
                <p class="text-[11px] text-green-500 font-medium">Connected</p>
              </div>
            </div>
          </div>
        `;
			}

			emptyState?.classList.add("hidden");
			activeState?.classList.remove("hidden");
			activeState?.classList.add("flex");

			socket?.emit(SOCKET_EVENTS.JOIN_CHAT, { chatId: activeChatId });
		}
	});

	// =========================================================================
	// SEND MESSAGE & TYPING
	// =========================================================================
	messageInput?.addEventListener("input", () => {
		if (activeChatId && socket) socket.emit("typing", { chatId: activeChatId });
	});

	chatForm?.addEventListener("submit", (e) => {
		e.preventDefault();
		const text = messageInput?.value.trim();
		if (!text || !activeChatId) return;
		socket?.emit(SOCKET_EVENTS.SEND_MESSAGE, { chatId: activeChatId, text });
		if (messageInput) messageInput.value = "";
	});

	// =========================================================================
	// MODAL LOGIC
	// =========================================================================
	document.getElementById("open-add-modal")?.addEventListener("click", () => {
		document.dispatchEvent(new CustomEvent("open-add-modal"));
	});

	document.addEventListener("contact-selected", async (e: Event) => {
		const customEvent = e as CustomEvent;
		const { user } = customEvent.detail;

		try {
			const res = await fetch("http://localhost:3000/api/chats/create", {
				method: "POST",
				credentials: "include",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					name: `Chat con ${user.username}`,
					isGroupChat: false,
					participantIds: [user.id || user._id],
				}),
			});

			const newChat = await res.json();
			if (!res.ok) throw new Error(newChat.error || "Failed to create chat");

			if (sidebarList) {
				const chatItemLink = document.createElement("a");
				chatItemLink.setAttribute("href", `/chat/${newChat._id || newChat.id}`);
				chatItemLink.className =
					"chat-trigger block p-3 rounded-xl transition-all hover:bg-slate-100 bg-white shadow-sm border border-gray-100 flex flex-row items-center gap-3 cursor-pointer mb-2 animate-fade-in";

				chatItemLink.innerHTML = `
          <div class="relative w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold">
            ${user.username.charAt(0).toUpperCase()}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-row justify-between items-baseline">
              <h3 class="text-sm font-semibold text-slate-800 truncate">${user.username}</h3>
              <span class="text-[10px] text-green-500 font-medium">New</span>
            </div>
          </div>
        `;

				if (sidebarList.querySelector("p")) sidebarList.innerHTML = "";
				sidebarList.insertBefore(chatItemLink, sidebarList.firstChild);

				// Auto-open newly created chat
				chatItemLink.click();
			}
		} catch (error) {
			console.error("Error creating new chat:", error);
			alert("There was a problem adding the new contact.");
		}
	});
</script>
