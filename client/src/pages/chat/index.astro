---
export const prerender = false;

import MainLayout from "../../layouts/MainLayout.astro";
import SearchField from "../../components/SearchField.astro";
import chatIcon from "../../assets/icon/green/chat.svg?url";

import ChatHeader from "../../components/ChatHeader.astro";
import TypeBox from "../../components/TypeBox.astro";
import TypingIndicator from "../../components/TypingIndicator.astro";

import Button from "../../components/Button.astro";
import PlusIcon from "../../assets/icon/outlined/plus.svg?url";
import AddModal from "../../components/AddModal.astro";
import BackIcon from "../../assets/icon/green/back.svg?url";

let currentUserId = "";

try {
  // Get the current user's ID from the backend to use in the chat page
  const authRes = await fetch("http://localhost:3000/api/auth/me", {
    headers: { Cookie: Astro.request.headers.get("cookie") || "" },
  });

  if (authRes.ok) {
    const userData = await authRes.json();

    // Extract id
    currentUserId = userData.userId;

    console.log("Current user ID:", userData);
  } else {
    return Astro.redirect("/");
  }
} catch (error) {
  console.error("Error validando la sesión del usuario:", error);
  return Astro.redirect("/");
}
---

<MainLayout title="Chat" active="Chat" container="w-full">
  <div
    class="flex h-screen"
    data-my-user-id={currentUserId}
    id="chat-container"
  >
    <!-- SIDEBAR -->
    <div
      id="chat-sidebar"
      class="w-full lg:w-96 p-4 flex flex-col shadow-lg bg-bg"
    >
      <div class="flex flex-row justify-between items-center">
        <h1
          class="text-3xl font-bold mb-4 flex items-center gap-2 text-primary-60"
        >
          <img src={chatIcon} alt="Chat Icon" class="h-8 w-8" />
          Chat
        </h1>
        <Button
          id="open-add-modal"
          variant="primary"
          class="text-sm mb-4 cursor-pointer"
        >
          <img src={PlusIcon} alt="Add contact" class="h-5 w-5" />
          Add Contact
        </Button>
      </div>

      <SearchField placeholder="Search..." />

      <div id="chat-sidebar-list" class="mt-4 space-y-2 overflow-y-auto flex-1">
        <p id="chat-list-status" class="text-xs text-gray-400 text-center py-4">
          Loading active chats...
        </p>
      </div>
    </div>

    <!-- CHAT WINDOW -->
    <div id="chat-content" class="hidden lg:flex flex-1 relative flex-col">
      <div
        id="empty-chat-state"
        class="absolute inset-0 flex items-center justify-center z-10"
      >
        <div class="home-bg absolute inset-0 opacity-30 pointer-events-none">
        </div>
        <p
          class="text-gray-500 text-lg text-center z-10 bg-bg/60 rounded-full px-4 py-2"
        >
          Select a room to start messaging
        </p>
      </div>

      <div id="active-chat-state" class="hidden flex-col h-full z-20 bg-bg">
        <!-- Back button (mobile/tablet only) -->
        <div
          class="flex items-center border-b border-gray-200 p-1 lg:hidden bg-bg z-10"
        >
          <button
            id="back-to-sidebar-btn"
            class="inline-flex items-center gap-2 px-3 py-2 rounded-lg font-medium text-primary hover:bg-primary-10 transition-colors"
          >
            <img src={BackIcon} alt="Back" class="h-5 w-5" />
            Back
          </button>
        </div>

        <ChatHeader
          name="Active Chat"
          status="online"
          avatar=""
          lastTimestamp="Now"
        />

        <div class="home-bg absolute inset-0 opacity-40 pointer-events-none">
        </div>

        <div
          id="messages-list"
          class="relative flex-1 overflow-y-auto px-6 py-4 flex flex-col gap-1"
        >
        </div>

        <div id="typing-indicator-wrapper" class="hidden">
          <TypingIndicator message="Someone is typing ..." />
        </div>

        <div id="typebox-container">
          <TypeBox />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<AddModal />

<script>
  import { initializeSocket, SOCKET_EVENTS } from "../../lib/socket";

  // =========================================================================
  // HELPER: FORMAT TIMESTAMP
  // =========================================================================
  function getTimeAgo(date: string | Date) {
    if (!date || date === "null") return "offline";
    const now = new Date();
    const past = new Date(date);
    const diff = now.getTime() - past.getTime();

    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(minutes / 60);
    const days = Math.floor(hours / 24);

    if (minutes < 1) return "just now";
    if (minutes < 60) return `${minutes}m ago`;
    if (hours < 24) return `${hours}h ago`;
    return `${days}d ago`;
  }

  // 1. DOM Elements
  const chatListStatus = document.getElementById("chat-list-status");
  const emptyState = document.getElementById("empty-chat-state");
  const activeState = document.getElementById("active-chat-state");
  const messagesList = document.getElementById("messages-list");
  const chatContainer = document.getElementById("chat-container");
  const chatSidebar = document.getElementById("chat-sidebar");
  const chatContent = document.getElementById("chat-content");
  const sidebarList = document.getElementById("chat-sidebar-list");
  const chatHeaderWrapper = document.getElementById("chat-header-wrapper");

  const typingIndicatorWrapper = document.getElementById(
    "typing-indicator-wrapper",
  );
  const chatForm = document.getElementById("chat-form");
  const messageInput = document.getElementById(
    "message-input",
  ) as HTMLInputElement;

  let activeChatId: string | null = null;
  const myUserId = chatContainer?.getAttribute("data-my-user-id");

  // 2. Initialize Socket Connection
  const socket = initializeSocket("http://localhost:3000");

  // =========================================================================
  // BACK TO SIDEBAR LOGIC (MOBILE ONLY)
  // =========================================================================
  document
    .getElementById("back-to-sidebar-btn")
    ?.addEventListener("click", () => {
      if (activeChatId && socket) {
        socket.emit(SOCKET_EVENTS.LEAVE_CHAT, { chatId: activeChatId });
      }
      activeChatId = null;
      chatContent?.classList.add("hidden");
      chatContent?.classList.remove("flex");
      chatSidebar?.classList.remove("hidden");
      activeState?.classList.add("hidden");
      activeState?.classList.remove("flex");
      emptyState?.classList.remove("hidden");
    });

  // =========================================================================
  // HELPER: RENDER CHAT IN SIDEBAR
  // =========================================================================
  function addChatToSidebar(chat: any, isNew: boolean = false) {
    if (!sidebarList) return;

    // Remove "loading" or "empty" state if it exists
    if (sidebarList.querySelector("p")) {
      sidebarList.querySelector("p")?.remove();
    }

    // Use fallback name if backend returns null
    const displayName = chat.name || chat.fallbackName || "Chat";
    let statusText = "offline";
    if (isNew) {
      statusText = "New";
    } else if (chat.status === "online") {
      statusText = "online";
    } else if (chat.lastActiveAt) {
      statusText = getTimeAgo(chat.lastActiveAt); // Muestra "5m ago" en lugar de "offline"
    }
    const statusColor = isNew
      ? "text-green"
      : chat.status === "online"
        ? "text-green"
        : "text-gray-400";

    // Extract status from API or default to offline
    const userPresenceStatus = chat.status || "offline";

    // Check if chat already exists in UI to avoid duplicates
    let chatItemLink = document.getElementById(
      `sidebar-item-${chat.id}`,
    ) as HTMLAnchorElement;

    if (!chatItemLink) {
      chatItemLink = document.createElement("a");
      chatItemLink.id = `sidebar-item-${chat.id}`;
      chatItemLink.setAttribute("href", `/chat/${chat.id}`);
      chatItemLink.className =
        "block p-3 rounded-xl transition-all hover:bg-gray-50 bg-white shadow-sm border border-gray-100 flex flex-row items-center gap-3 cursor-pointer mb-2 animate-fade-in";
    }

    // Bind the real-time status to the DOM element
    chatItemLink.setAttribute("data-status", userPresenceStatus);
    chatItemLink.setAttribute("data-last-active", chat.lastActiveAt || "null");

    chatItemLink.innerHTML = `
      <div class="relative w-10 h-10 rounded-full bg-primary-20 flex items-center justify-center text-primary font-bold">
        ${displayName.charAt(0).toUpperCase()}
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex flex-row justify-between items-baseline">
          <h3 class="text-sm font-semibold text-text-black truncate">${displayName}</h3>
          <span class="sidebar-chat-status text-[10px] ${statusColor} font-medium">${statusText}</span>
        </div>
      </div>
    `;

    // Add it to the top of the list
    sidebarList.insertBefore(chatItemLink, sidebarList.firstChild);
    return chatItemLink;
  }

  // =========================================================================
  // HELPER: RENDER A SINGLE MESSAGE BUBBLE
  // =========================================================================
  function renderMessage(message: any) {
    if (!messagesList) return;

    // console.log("[Socket] Rendering message:", message);

    // Aseguramos capturar el ID sin importar cómo lo mande el backend
    const sender = message.senderId;
    const isOwn = sender === myUserId;

    console.log(
      `[Message Render] Sender: ${sender}, Is Own: ${isOwn}, User ID: ${myUserId}`,
    );

    const wrapperDiv = document.createElement("div");
    // Other user's messages are aligned to the left, yours to the right
    wrapperDiv.className = `flex ${isOwn ? "justify-end" : "justify-start"} mb-1`;

    const bubbleDiv = document.createElement("div");
    // User's own messages are green, others are white with a border
    bubbleDiv.className = `relative max-w-xs lg:max-w-md px-4 py-2.5 rounded-2xl text-sm shadow-sm ${
      isOwn
        ? "bg-green text-text-black rounded-br-sm"
        : "bg-white text-text-black rounded-bl-sm border border-gray-100"
    }`;

    const textElement = document.createElement("p");
    textElement.className = "leading-relaxed";
    textElement.textContent = message.text || message.content;

    bubbleDiv.appendChild(textElement);
    wrapperDiv.appendChild(bubbleDiv);
    messagesList.appendChild(wrapperDiv);

    messagesList.scrollTop = messagesList.scrollHeight;
  }

  // =========================================================================
  // 3. API INTEGRATION: FETCH ACTIVE CHATS FOR SIDEBAR
  // =========================================================================
  async function fetchUserChats() {
    try {
      const res = await fetch("http://localhost:3000/api/chats", {
        method: "GET",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
      });

      const chats = await res.json();
      if (!res.ok) throw new Error(chats.error || "Failed to fetch chats");

      if (sidebarList) {
        if (chatListStatus) chatListStatus.remove();

        const dmChats = chats.filter((chat: any) => !chat.isGroupChat);

        if (dmChats.length === 0) {
          sidebarList.innerHTML = `<p class="text-xs text-gray-400 text-center py-4">No active conversations found.</p>`;
          return;
        }

        // 3. Renderizar solo los DMs
        dmChats.reverse().forEach((chat: any) => addChatToSidebar(chat));
      }
    } catch (error) {
      console.error("[Frontend Error] Error loading sidebar chats:", error);
      if (sidebarList) {
        sidebarList.innerHTML = `<p class="text-xs text-red-500 text-center py-4">Error loading conversations.</p>`;
      }
    }
  }

  fetchUserChats();

  // =========================================================================
  // HELPER: OPEN CHAT MESSAGES IN MOBILE VIEW
  // =========================================================================
  function openChat(link: HTMLAnchorElement) {
    const href = link.getAttribute("href");
    const newChatId = href?.split("/").pop();

    if (!newChatId || newChatId === activeChatId) return;

    // 1. Leave current chat room if active
    if (activeChatId && socket) {
      socket.emit(SOCKET_EVENTS.LEAVE_CHAT, { chatId: activeChatId });
    }

    activeChatId = newChatId;

    // 1.5 Apply active visual feedback to the sidebar item
    const sidebarList = document.getElementById("chat-sidebar-list");
    if (sidebarList) {
      // 1. Remove active styles from all sidebar items and re-apply default styles
      const allLinks = sidebarList.querySelectorAll("a");
      allLinks.forEach((a) => {
        a.classList.remove("bg-primary-10", "border-primary", "shadow-md");
        a.classList.add(
          "bg-white",
          "border-gray-100",
          "shadow-sm",
          "hover:bg-gray-50",
        );
      });

      // 2. Apply active styles to the clicked item
      link.classList.remove(
        "bg-white",
        "border-gray-100",
        "shadow-sm",
        "hover:bg-gray-50",
      );
      link.classList.add("bg-primary-10", "border-primary", "shadow-md");
    }

    // 2. Extract the name from the clicked sidebar item
    // Targeting both .font-medium (spans) and h3 to prevent UI breakage
    const chatTitleEl = link.querySelector(".font-medium, h3");
    const currentChatName = chatTitleEl?.textContent
      ? chatTitleEl.textContent.trim()
      : "Unknown User";

    // 3. Update DOM elements for the header
    const headerNameEl = document.getElementById("chat-header-name");
    const headerAvatarEl = document.getElementById("chat-header-avatar");

    // Read status and timestamp from the sidebar item
    const currentStatus = link.getAttribute("data-status") || "offline";
    const currentLastActive = link.getAttribute("data-last-active");

    const statusTextEl = document.getElementById("chat-header-status-text");
    const statusDotEl = document.getElementById("chat-header-status-dot");
    const statusContainerEl = document.getElementById(
      "chat-header-status-container",
    );
    const headerTimestampEl = document.getElementById("chat-header-timestamp");

    // Apply Name
    if (headerNameEl) {
      headerNameEl.textContent = currentChatName;
    }

    // Apply Avatar Initials
    if (headerAvatarEl && currentChatName) {
      const initials = currentChatName
        .split(" ")
        .map((part) => part[0])
        .join("")
        .substring(0, 2)
        .toUpperCase();
      headerAvatarEl.textContent = initials;
    }

    // Apply Status UI (dot & text)
    if (statusTextEl) statusTextEl.textContent = currentStatus;
    if (statusDotEl) {
      statusDotEl.className = `h-2 w-2 rounded-full ${currentStatus === "online" ? "bg-green" : "bg-gray-300"}`;
    }
    if (statusContainerEl) {
      statusContainerEl.className = `flex items-center gap-1 text-sm font-medium ${currentStatus === "online" ? "text-green" : "text-gray-400"}`;
    }

    // Apply dynamic "last active" text to the header
    if (headerTimestampEl) {
      if (currentStatus === "online") {
        headerTimestampEl.textContent = "active now";
        headerTimestampEl.classList.remove("italic");
      } else if (currentLastActive && currentLastActive !== "null") {
        const d = new Date(currentLastActive);
        const timeStr = `${d.getHours().toString().padStart(2, "0")}:${d.getMinutes().toString().padStart(2, "0")}`;
        // headerTimestampEl.textContent = `last active ${getTimeAgo(currentLastActive)}`;
        headerTimestampEl.textContent = `Last time seen ${timeStr}`;
        headerTimestampEl.classList.remove("italic");
      } else {
        headerTimestampEl.textContent = "offline";
        headerTimestampEl.classList.add("italic");
      }
    }

    // Update the sidebar text to show the exact time (e.g. 5m ago) when clicked
    if (
      currentStatus === "offline" &&
      currentLastActive &&
      currentLastActive !== "null"
    ) {
      const sidebarStatusSpan = link.querySelector(".sidebar-chat-status");
      if (sidebarStatusSpan) {
        sidebarStatusSpan.textContent = getTimeAgo(currentLastActive);
      }
    }

    // 4. Toggle Chat Visibility (Desktop)
    emptyState?.classList.add("hidden");
    activeState?.classList.remove("hidden");
    activeState?.classList.add("flex");

    // 5. Mobile Responsiveness: hide sidebar, show chat content
    if (window.innerWidth < 1024) {
      const chatSidebar = document.getElementById("chat-sidebar");
      const chatContent = document.getElementById("chat-content");

      chatSidebar?.classList.add("hidden");
      chatSidebar?.classList.remove("flex"); // Ensure flex is fully removed

      chatContent?.classList.remove("hidden");
      chatContent?.classList.add("flex");
    }

    // 6. Join new chat room
    socket?.emit(SOCKET_EVENTS.JOIN_CHAT, { chatId: activeChatId });
  }

  // =========================================================================
  // 4. SOCKET EVENT REGISTRATION
  // =========================================================================
  if (socket) {
    let typingTimeout: any;

    socket.on(SOCKET_EVENTS.MESSAGE_HISTORY, (messages: any[]) => {
      if (messagesList) {
        messagesList.innerHTML = "";
        messages.forEach(renderMessage);
      }
    });

    socket.on(SOCKET_EVENTS.NEW_MESSAGE, (message: any) => {
      // Render message if it belongs to the currently active chat
      if (message.chatId === activeChatId) {
        renderMessage(message);

        // Hide typing indicator if visible since we just received a new message
        if (typingIndicatorWrapper) {
          typingIndicatorWrapper.classList.add("hidden");
          clearTimeout(typingTimeout);
        }
      }

      // Move chat to the top of the sidebar
      const existingSidebarItem = document.getElementById(
        `sidebar-item-${message.chatId}`,
      );
      if (existingSidebarItem && sidebarList) {
        sidebarList.prepend(existingSidebarItem);
      } else {
        fetchUserChats();
      }
    });

    // Listen for chats created by other users
    socket.on("NEW_CHAT_CREATED", (newChatData: any) => {
      console.log("[Socket] Received new chat notification:", newChatData);
      addChatToSidebar(newChatData, true);
    });

    socket.on("user_typing", (data: any) => {
      // 1. Validate that the typing event is for the currently active chat
      if (data.chatId !== activeChatId) return;

      if (typingIndicatorWrapper) {
        // 2. Search for the TypingIndicator element and update its message
        const typingTextEl = document.getElementById("typing-indicator");
        if (typingTextEl && data.username) {
          typingTextEl.textContent = `${data.username} is typing...`;
        }

        // 3. Show the typing indicator if it's hidden
        typingIndicatorWrapper.classList.remove("hidden");

        // 4. Hide the typing indicator after 3 seconds of inactivity
        clearTimeout(typingTimeout);
        typingTimeout = setTimeout(() => {
          typingIndicatorWrapper.classList.add("hidden");
        }, 1500);
      }
    });

    // User precence updates (online/offline)
    socket.on(SOCKET_EVENTS.USER_PRESENCE, (payload: any) => {
      console.log("[Socket] User presence changed:", payload);

      // Check if the current active chat belongs to the user whose status changed
      const headerNameEl = document.getElementById("chat-header-name");

      if (
        headerNameEl &&
        headerNameEl.textContent
          ?.toLowerCase()
          .includes(payload.username.toLowerCase())
      ) {
        const statusTextEl = document.getElementById("chat-header-status-text");
        const statusDotEl = document.getElementById("chat-header-status-dot");
        const statusContainerEl = document.getElementById(
          "chat-header-status-container",
        );
        const headerTimestampEl = document.getElementById(
          "chat-header-timestamp",
        );

        // Update text (online / offline)
        if (statusTextEl) {
          statusTextEl.textContent = payload.status;
        }

        // Update the green / gray dot indicator
        if (statusDotEl) {
          statusDotEl.className = `h-2 w-2 rounded-full ${
            payload.status === "online" ? "bg-green" : "bg-gray-300"
          }`;
        }

        // Update the text color in the container
        if (statusContainerEl) {
          statusContainerEl.className = `flex items-center gap-1 text-sm font-medium ${
            payload.status === "online" ? "text-green" : "text-gray-400"
          }`;
        }

        // Update the "last active" text in the header
        if (headerTimestampEl) {
          if (payload.status === "offline" && payload.lastActiveAt) {
            headerTimestampEl.textContent = `last active just now`;
            headerTimestampEl.classList.remove("italic");
          } else if (payload.status === "online") {
            headerTimestampEl.textContent = "active now";
            headerTimestampEl.classList.remove("italic");
          }
        }
      }
      // Keep sidebar items synchronized so clicks always fetch the latest status
      const allSidebarLinks = document.querySelectorAll("#chat-sidebar-list a");
      allSidebarLinks.forEach((sidebarLink) => {
        const nameEl = sidebarLink.querySelector("h3");

        // Apply case insensitive matching
        if (
          nameEl &&
          nameEl.textContent
            ?.toLowerCase()
            .includes(payload.username.toLowerCase())
        ) {
          // 1. Update the hidden data attribute
          sidebarLink.setAttribute("data-status", payload.status);

          if (payload.status === "offline" && payload.lastActiveAt) {
            sidebarLink.setAttribute("data-last-active", payload.lastActiveAt);
          }

          // 2. Update the visual text and color in the sidebar
          const statusSpan = sidebarLink.querySelector(".sidebar-chat-status");
          if (statusSpan) {
            if (payload.status === "online") {
              statusSpan.textContent = "online";
              statusSpan.classList.remove("text-gray-400", "text-text-gray");
              statusSpan.classList.add("text-green");
            } else {
              // Muestra "just now" al instante de desconectarse
              statusSpan.textContent = payload.lastActiveAt
                ? "just now"
                : "offline";
              statusSpan.classList.remove("text-green");
              statusSpan.classList.add("text-gray-400");
            }
          }
        }
      });
    });
  }

  // =========================================================================
  // 5. NAVIGATION INTERCEPTION (SPA ROUTING) & ROOM LEAVING
  // =========================================================================
  sidebarList?.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest("a");
    if (!link) return;

    e.preventDefault();
    openChat(link as HTMLAnchorElement);
  });

  // =========================================================================
  // 6. TYPING & MESSAGE SEND HANDLERS
  // =========================================================================
  messageInput?.addEventListener("input", () => {
    if (activeChatId && socket) {
      socket.emit("typing", { chatId: activeChatId });
    }
  });

  chatForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    const text = messageInput?.value.trim();

    if (!text || !activeChatId) return;
    socket?.emit(SOCKET_EVENTS.SEND_MESSAGE, { chatId: activeChatId, text });
    if (messageInput) messageInput.value = "";
  });

  // =========================================================================
  // 7. MODAL LOGIC
  // =========================================================================
  document.getElementById("open-add-modal")?.addEventListener("click", () => {
    document.dispatchEvent(new CustomEvent("open-add-modal"));
  });

  // =========================================================================
  // 8. ADDING CONTACT FROM MODAL
  // =========================================================================
  document.addEventListener("contact-selected", async (e: Event) => {
    const customEvent = e as CustomEvent;
    const { user } = customEvent.detail;

    try {
      const res = await fetch("http://localhost:3000/api/chats/create", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: `${user.username}`,
          isGroupChat: false,
          participantIds: [user.id],
        }),
      });

      const newChat = await res.json();
      if (!res.ok) throw new Error(newChat.error || "Failed to create chat");

      // Pass the modal username as a fallback name
      newChat.fallbackName = user.username;

      // Inject into sidebar
      const chatItemLink = addChatToSidebar(newChat, true);

      // Open the chat immediately
      if (chatItemLink) chatItemLink.click();
    } catch (error) {
      console.error("Error creating new chat with contact:", error);
      alert("There was a problem adding the new contact.");
    }
  });
</script>
