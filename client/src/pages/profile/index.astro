---
import MainLayout from "../../layouts/MainLayout.astro";
import Button from "../../components/Button.astro";
import TextField from "../../components/TextField.astro";

let userData = { username: "Loading...", email: "Loading..." };

try {
  const res = await fetch("http://localhost:3000/api/users/me", {
    headers: { 
      Cookie: Astro.request.headers.get("cookie") || "" 
    },
  });

  if (res.ok) {
    userData = await res.json();
    console.log("userData loaded:", userData);
  } else {
    console.log("Fetch failed:", res.status);
  }
} catch (err) {
  console.error("Fetch error:", err);
}

const initialLetter = userData.username && userData.username !== "Loading..."
  ? userData.username.charAt(0).toUpperCase()
  : "U";
---

<MainLayout title="Profile Settings" active="Profile" container="w-full">
  <div class="flex flex-col min-h-screen items-center justify-center login-bg py-8 px-4">
    <div class="rounded-2xl bg-bg/90 p-6 mb-12 md:p-8 md:mb-0 shadow-xl w-full max-w-2xl">
      <div class="text-center">
        <h1 class="font-display text-3xl md:text-4xl font-bold text-text-black">
          Profile Settings
        </h1>
        <p class="mt-1 mb-6 text-sm text-text-gray">
          Edit your profile information.
        </p>
      </div>

      <div class="flex flex-col md:flex-row items-center md:items-start justify-center gap-8 md:gap-10">
        
        <div class="flex flex-col items-center gap-3">
          <div
            id="profile-avatar"
            class="h-32 w-32 md:h-44 md:w-44 rounded-full bg-yellow-500 flex items-center justify-center overflow-hidden cursor-pointer transition-colors"
            role="button"
            tabindex="0"
            aria-label="Randomize profile color"
          >
            <span id="profile-avatar-initial" class="text-5xl md:text-6xl font-bold text-text-black leading-none">{initialLetter}</span>
          </div>

          <div class="text-center">
            <p class="text-text-gray font-normal text-xs">
              Username: <span class="font-bold text-text-black">{userData.username}</span>
            </p>
            <p class="text-text-gray font-normal text-xs mt-1">
              Email: <span class="font-bold text-text-black">{userData.email}</span>
            </p>
          </div>

          <!-- <p class="mt-1 max-w-52 text-center text-xs leading-5 text-text-gray">
            Click the avatar to randomize your profile color.
          </p> -->
        </div>

        <div class="flex flex-col gap-4 w-full md:w-80">
          <div class="flex flex-col gap-1">
            <TextField name="username" label="Username" placeholder="Enter your username" maxlength="15" />
            <p id="username-error" class="error-msg text-red-500 text-xs min-h-4"></p>
          </div>

          <div class="flex flex-col gap-1">
            <TextField name="email" label="Email" placeholder="Enter your email" />
            <p id="email-error" class="error-msg text-red-500 text-xs min-h-4"></p>
          </div>

          <div class="flex flex-col gap-1 relative">
            <TextField name="currentPassword" type="password" label="Current Password" placeholder="••••••••" class="w-full" />
            <span id="toggleCurrent" class="absolute right-3 top-8.5 cursor-pointer text-xs text-gray-500 select-none">Show</span>
            <p id="currentPassword-error" class="error-msg text-red-500 text-xs min-h-4"></p>
          </div>

          <div class="flex flex-col gap-1 relative">
            <TextField name="newPassword" type="password" label="New Password" placeholder="••••••••" class="w-full" />
            <span id="toggleNew" class="absolute right-3 top-8.5 cursor-pointer text-xs text-gray-500 select-none">Show</span>
            <p class="text-gray-400 text-[10px] mt-0">At least 5 chars, 1 uppercase, 1 number, 1 special char</p>
            <p id="newPassword-error" class="error-msg text-red-500 text-xs min-h-4"></p>
          </div>

          <Button id="save-btn" variant="primary" class="w-full cursor-pointer mt-2">Save Profile</Button>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  const saveBtn = document.getElementById("save-btn") as HTMLElement;
  const inputs = document.querySelectorAll("input") as NodeListOf<HTMLInputElement>;
  const disabledClasses = ["bg-text-gray", "border-gray-300", "pointer-events-none", "opacity-60"];

  saveBtn.classList.add(...disabledClasses);

  const checkForm = (): void => {
    let hasValue = false;
    inputs.forEach(input => { if (input.value.trim().length > 0) hasValue = true; });
    
    if (hasValue) saveBtn.classList.remove(...disabledClasses);
    else saveBtn.classList.add(...disabledClasses);
  };

  const avatar = document.getElementById("profile-avatar") as HTMLElement;
  const colors = ["bg-red-500", "bg-blue-500", "bg-green-500", "bg-yellow-500", "bg-purple-500", "bg-pink-500"];
  avatar?.addEventListener("click", () => {
    const currentColor = colors.find(c => avatar.classList.contains(c));
    const randomColor = colors[Math.floor(Math.random() * colors.length)];
    if (currentColor) avatar.classList.remove(currentColor);
    avatar.classList.add(randomColor);
  });

  const toggleVisibility = (btnId: string, inputName: string) => {
    const btn = document.getElementById(btnId);
    const input = document.querySelector(`input[name="${inputName}"]`) as HTMLInputElement;
    btn?.addEventListener("click", () => {
      const isPass = input.type === "password";
      input.type = isPass ? "text" : "password";
      btn.textContent = isPass ? "Hide" : "Show";
    });
  };
  toggleVisibility("toggleCurrent", "currentPassword");
  toggleVisibility("toggleNew", "newPassword");

  document.querySelectorAll("input").forEach((input) => {
    input.addEventListener("input", () => {
      input.style.borderColor = "";
      const errorEl = document.getElementById(`${input.getAttribute("name")}-error`);
      if (errorEl) errorEl.textContent = "";
      checkForm();
    });
  });

  saveBtn?.addEventListener("click", async () => {
    if (saveBtn.classList.contains("pointer-events-none")) return;

    document.querySelectorAll(".error-msg").forEach(el => (el as HTMLElement).textContent = "");
    document.querySelectorAll("input").forEach(el => (el as HTMLElement).style.borderColor = "");

    const username = (document.querySelector('input[name="username"]') as HTMLInputElement).value;
    const email = (document.querySelector('input[name="email"]') as HTMLInputElement).value;
    const currentPassword = (document.querySelector('input[name="currentPassword"]') as HTMLInputElement).value;
    const newPassword = (document.querySelector('input[name="newPassword"]') as HTMLInputElement).value;

    if (username && username.length > 15) {
      document.getElementById("username-error")!.textContent = "Username must be 15 characters or less";
      (document.querySelector('input[name="username"]') as HTMLElement).style.borderColor = "red";
      return;
    }

    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      document.getElementById("email-error")!.textContent = "Invalid email format";
      (document.querySelector('input[name="email"]') as HTMLElement).style.borderColor = "red";
      return;
    }

    const passwordRegex = /^(?=.*[A-Z])(?=.*[0-9])(?=.*[!@#$%^&*])(?=.{5,})/;
    if (newPassword && !passwordRegex.test(newPassword)) {
      document.getElementById("newPassword-error")!.textContent = "New password does not meet requirements";
      (document.querySelector('input[name="newPassword"]') as HTMLElement).style.borderColor = "red";
      return;
    }

    if (!currentPassword) {
      document.getElementById("currentPassword-error")!.textContent = "Current password is required";
      (document.querySelector('input[name="currentPassword"]') as HTMLElement).style.borderColor = "red";
      return;
    }

    const payload: any = { currentPassword };
    if (username) payload.username = username;
    if (email) payload.email = email;
    if (newPassword) payload.newPassword = newPassword;

    try {
      const res = await fetch("http://localhost:3000/api/users/profile", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify(payload),
      });

      const result = await res.json();

      if (!res.ok) {
        const errorEl = document.getElementById(`${result.field}-error`);
        if (errorEl) {
          errorEl.textContent = result.error;
          const targetInput = document.querySelector(`input[name="${result.field}"]`) as HTMLElement;
          targetInput.style.borderColor = "red";
        }
      } else {
        alert("Profile updated successfully!");
        window.location.reload();
      }
    } catch (err) {
      console.error(err);
    }
  });
</script>