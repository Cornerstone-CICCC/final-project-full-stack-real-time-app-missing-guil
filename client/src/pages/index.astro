---
import AuthLayout from "../layouts/AuthLayout.astro";
import Button from "../components/Button.astro";
import TextField from "../components/TextField.astro";
import CheckBox from "../components/CheckBox.astro";

const res = await fetch("http://localhost:3000/api/auth/me", {
  headers: { Cookie: Astro.request.headers.get("cookie") || "" },
});

if (res.ok) {
  return Astro.redirect("/home");
}
---

<AuthLayout title="Log in" container="max-w-md">
  <h1 class="font-display text-5xl font-bold text-text-black">Log in</h1>
  <p id="status-msg" class="mt-1 mb-6 text-sm text-text-gray">
    Please enter your account details
  </p>

  <form id="loginForm" class="space-y-4" method="post">
    <div class="space-y-1">
      <TextField name="email" placeholder="Email" />
    </div>

    <div class="space-y-1">
      <div class="relative flex items-center">
        <TextField
          name="password"
          type="password"
          placeholder="••••••••"
          class="w-full"
        />
        <span
          id="togglePassword"
          class="absolute right-3 cursor-pointer text-xs text-gray-500 select-none"
          >Show</span
        >
      </div>
    </div>

    <div class="flex items-center justify-between pt-1">
      <CheckBox name="remember">Remember me</CheckBox>
    </div>

    <Button id="loginBtn" type="button" variant="primary" class="w-full"
      >Log in</Button
    >
  </form>

  <p class="mt-5 text-center text-sm text-text-gray">
    Don't have an account?
    <a href="/register" class="font-medium hover:underline text-primary"
      >Register</a
    >
  </p>
</AuthLayout>

<script>
  const btn = document.getElementById("loginBtn");
  const statusMsg = document.getElementById("status-msg");
  const togglePass = document.getElementById("togglePassword");
  const passInput = document.querySelector('input[name="password"]') as HTMLInputElement;

  // Show/Hide Password
  togglePass?.addEventListener("click", () => {
    const isPassword = passInput.type === "password";
    passInput.type = isPassword ? "text" : "password";
    togglePass.textContent = isPassword ? "Hide" : "Show";
  });

  document.querySelectorAll("input").forEach((input) => {
    input.addEventListener("input", () => {
      if (statusMsg) {
        statusMsg.textContent = "Please enter your account details";
        statusMsg.style.color = "";
      }
    });
  });

  btn?.addEventListener("click", async () => {
    const email = (
      document.querySelector('input[name="email"]') as HTMLInputElement
    ).value;
    const password = passInput.value;
    const remember = (
      document.querySelector('input[name="remember"]') as HTMLInputElement
    ).checked;

    if (!email || !password) {
      if (statusMsg) {
        statusMsg.textContent = "Invalid credentials";
        statusMsg.style.color = "red";
      }
      return;
    }

    try {
      const res = await fetch("http://localhost:3000/api/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ email, password, remember }),
      });

      if (!res.ok) {
        if (statusMsg) {
          statusMsg.textContent = "Invalid credentials";
          statusMsg.style.color = "red";
        }
      } else {
        window.location.href = "/home";
      }
    } catch (err) {
      alert("Server connection failed.");
    }
  });
</script>